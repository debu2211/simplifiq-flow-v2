PORT=3020

# Required for AI report generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional. Leave blank if you do not want external search enrichment.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Google OAuth for Drive and Sheets.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3020/oauth2callback

# Google Drive folder where PDFs should be uploaded.
GOOGLE_DRIVE_FOLDER_ID=

# Google Sheet where form rows should be added.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Sheet1!A:J
